    "import json\n",
    "\n",
    "def load_data(file_path):\n",
    "    with open(file_path, 'r') as file:\n",
    "        return json.load(file)\n",
    "\n",
    "data = load_data('data/dataset.json')\n",
    "print(f\"Loaded {len(data['users'])} users and {len(data['pages'])} pages.\")"
   ]
